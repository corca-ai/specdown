{
  "entry": "specs/index.spec.md",
  "adapters": [],
  "reporters": [
    { "builtin": "html", "outFile": "specs/report" },
    { "builtin": "json", "outFile": "specs/report.json" }
  ],
  "models": { "builtin": "alloy" },
  "trace": {
    "types": ["spec", "guide"],
    "ignore": [".tmp-test/**", "specs/.tmp-test/**", ".claude/**", "cmd/**", "docs/**", "examples/**", "internal/**"],
    "edges": {
      "depends":  { "from": "spec",  "to": "spec",  "acyclic": true, "transitive": true },
      "explains": { "from": "guide", "to": "spec",  "count": "0..* → 1..*" }
    }
  }
}
